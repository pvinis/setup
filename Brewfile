# Homebrew package manifest.
#
# Applied by macos/brew.sh via `brew bundle --file=Brewfile`.
# Idempotent: brew bundle only installs what's missing, and leaves the rest alone.
#
# Right now this is a curated top 10 to bootstrap a machine. The remaining current
# leaves are listed (commented) below so migrating is just uncommenting.

# --- top 10: foundational, install these first ---
brew "git"       # distributed version control
brew "gh"        # GitHub CLI (used constantly here)
brew "mise"      # polyglot runtime manager (my default toolchain manager)
brew "chezmoi"   # dotfiles manager (central to this setup repo's plan)
brew "fish"      # my shell
brew "neovim"    # editor
brew "fzf"       # command-line fuzzy finder
brew "zoxide"    # smarter cd / directory jumping
brew "fd"        # fast, friendly find
brew "bat"       # cat with syntax highlighting + git integration

