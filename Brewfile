# Homebrew package manifest.
#
# Applied by macos/brew.sh via `brew bundle --file=Brewfile`.
# Idempotent: brew bundle only installs what's missing, and leaves the rest alone.
#
# The active list below is the curated set we're managing right now. The remaining
# current leaves are listed commented-out, so growing this is just uncommenting.
# (Commenting something out here does NOT uninstall it; it just stops managing it.)

# --- foundational ---
brew "git"       # distributed version control
brew "gh"        # GitHub CLI (used constantly here)
brew "mise"      # polyglot runtime manager (my default toolchain manager)

# --- editor + shell tooling ---
brew "neovim"    # editor
brew "zoxide"    # smarter cd / directory jumping
brew "fzf"       # command-line fuzzy finder

# --- utilities ---
brew "direnv"    # load/unload env vars based on $PWD
brew "mas"       # Mac App Store CLI
brew "thefuck"   # correct mistyped previous command

